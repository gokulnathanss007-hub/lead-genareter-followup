# =============================================================================
# .env.example — copy this to .env and fill in your real values
# Never commit .env — it is gitignored
# =============================================================================

# ── Twilio ────────────────────────────────────────────────────────────────────
# Get from: console.twilio.com → Account Info (top left dashboard)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Include the whatsapp: prefix. Sandbox number: whatsapp:+14155238886
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Full public URL of the webhook endpoint — used for Twilio signature validation.
# For local dev: run `npx ngrok http 3000` and paste the https URL here.
# For production (Render): https://<your-app>.onrender.com/webhook/whatsapp
# Leave blank to skip signature validation (local dev only).
TWILIO_WEBHOOK_URL=

# ── NVIDIA LLaMA ──────────────────────────────────────────────────────────────
# Get API key from: build.nvidia.com → Get API Key
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Base URL for NVIDIA hosted inference (do not change unless using a different endpoint)
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
# Model name — see build.nvidia.com for available models
NVIDIA_MODEL=meta/llama-4-maverick-17b-128e-instruct

# ── ClickUp ───────────────────────────────────────────────────────────────────
# Get from: app.clickup.com → Settings → Apps → API Token
CLICKUP_API_KEY=pk_xxxxxxxxx_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Get from the URL of your "Dental Leads" list in ClickUp
# e.g. app.clickup.com/90166718340/v/li/901614338320  →  901614338320
CLICKUP_LIST_ID=xxxxxxxxxxxx

# ── Trigger.dev ───────────────────────────────────────────────────────────────
# Get from: cloud.trigger.dev → your project → Settings → API Keys
TRIGGER_SECRET_KEY=tr_dev_xxxxxxxxxxxxxxxxxxxxxxxx

# ── Clinic Context (injected into the AI system prompt) ──────────────────────
CLINIC_NAME=Smile Dental Clinic
CLINIC_SERVICES=teeth cleaning, root canal, fillings, teeth whitening, dental checkup
CLINIC_HOURS=Monday to Saturday, 9am to 6pm

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
# Options: debug | info | warn | error
LOG_LEVEL=info
